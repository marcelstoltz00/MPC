# Application
PORT=3001
NODE_ENV=development

# Database Connection (Matches docker-compose exactly)
DB_HOST=localhost
DB_PORT=5435
DB_USER=postgres
DB_PASSWORD=password123
DB_NAME=misp_db

# TypeORM Connection String
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Authentication (For the User Team's JWT implementation)
JWT_SECRET=this_is_a_local_development_secret
JWT_EXPIRATION=3600s